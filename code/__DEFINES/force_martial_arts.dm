/// Cooldown between attempts to use a Force grab.
#define FORCE_GRAB_COOLDOWN 3 SECONDS

/// Max tiles away the user can use a Force grab (/datum/martial_art/force).
#define FORCE_GRAB_MAX_DISTANCE 6

/// Cooldown between attempts to use a Force lightning.
#define FORCE_LIGHTNING_COOLDOWN 10 SECONDS

/// Max tiles away the user can use a Force lightning (/datum/martial_art/force).
#define FORCE_LIGHTNING_MAX_DISTANCE 4

/// How long Force lightning stuns the primary target.
#define FORCE_LIGHTNING_STUN_DURATION 1 SECONDS

/// Electrocute power (burn damage) for mobs hit along the lightning line (excluding the primary target).
#define FORCE_LIGHTNING_CHAIN_POWER 15

/// Electrocute power (burn damage) for the primary lightning target.
#define FORCE_LIGHTNING_PRIMARY_POWER 30
